# Tandril Environment Variables
# Copy this file to .env for local development

# ===========================================
# STANDALONE MODE
# ===========================================
# Set to 'true' to run in demo mode (no real authentication)
# Set to 'false' to enable real authentication (Supabase or Base44)
VITE_STANDALONE_MODE=true

# ===========================================
# SUPABASE CONFIGURATION (Recommended)
# ===========================================
# Supabase provides authentication, database, and serverless functions
# To set up Supabase:
# 1. Create a project at https://app.supabase.com
# 2. Get your project URL and anon key from Settings > API
# 3. Get your service role key (used for Edge Functions)
# 4. Set VITE_STANDALONE_MODE=false
# 5. Fill in the values below

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# These are used in Supabase Edge Functions (not frontend)
# Set these in your Supabase project settings under Edge Functions > Secrets
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# APP_URL=https://your-app.vercel.app

# ===========================================
# BASE44 CONFIGURATION (Alternative)
# ===========================================
# Only needed if using Base44 instead of Supabase

# VITE_API_BASE_URL=https://api.base44.com
# VITE_BASE44_API_KEY=your_api_key_here

# ===========================================
# SHOPIFY INTEGRATION
# ===========================================
# To connect Shopify stores:
# 1. Create a Shopify app at https://partners.shopify.com
# 2. Set up OAuth with your app's credentials
# 3. Add these to Supabase Edge Functions secrets:

# Set these in Supabase Edge Functions > Secrets:
# SHOPIFY_API_KEY=your_shopify_api_key
# SHOPIFY_API_SECRET=your_shopify_api_secret
# SHOPIFY_SCOPES=read_products,write_products,read_orders,read_inventory,write_inventory
# SHOPIFY_REDIRECT_URI=https://your-project.supabase.co/functions/v1/shopify-auth-callback
# ENCRYPTION_SECRET=your_strong_random_secret_32_chars_or_more  (REQUIRED - used to encrypt stored access tokens)

# ===========================================
# AI INTEGRATION (Optional but Recommended)
# ===========================================
# For command interpretation and AI features
# Choose one: Anthropic Claude (recommended) or OpenAI

# Set these in Supabase Edge Functions > Secrets:
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OR
# OPENAI_API_KEY=your_openai_api_key

# ===========================================
# BIGCOMMERCE OAUTH INTEGRATION
# ===========================================
# To connect BigCommerce stores via OAuth:
# 1. Create a BigCommerce app at https://devtools.bigcommerce.com
# 2. Set OAuth callback URL to https://your-app.vercel.app/oauth-callback
# 3. Add these to Supabase Edge Functions > Secrets:

# Set these in Supabase Edge Functions > Secrets:
# BIGCOMMERCE_CLIENT_ID=your_bigcommerce_client_id
# BIGCOMMERCE_CLIENT_SECRET=your_bigcommerce_client_secret

# ===========================================
# FAIRE OAUTH INTEGRATION
# ===========================================
# To connect Faire brand accounts via OAuth:
# 1. Apply for Faire API access at https://faire.github.io/external-api-docs/
# 2. Set OAuth callback URL to https://your-app.vercel.app/oauth-callback
# 3. Add these to Supabase Edge Functions > Secrets:

# Set these in Supabase Edge Functions > Secrets:
# FAIRE_CLIENT_ID=your_faire_client_id
# FAIRE_CLIENT_SECRET=your_faire_client_secret

# ===========================================
# EMAIL (RESEND)
# ===========================================
# Resend is used to send beta invite emails and transactional emails.
# 1. Sign up at https://resend.com and create an API key
# 2. Add and verify your sending domain in Resend > Domains
# 3. Add the DNS records below at your domain registrar, then click "Verify" in Resend
#
# Required DNS records (add at your domain registrar):
#   DKIM  TXT  resend._domainkey.{YOUR_DOMAIN}
#              p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQC88Ir3FFZRj8HclYo63sv8ZdbMjxZ
#                L9ziH4bsXO14fQdcHGz8d5Pkodpra9seLHRd3bPDOVsBz67qTfMeK/f066DMxjOj2mj
#                UuNEARWDDslgTU/2l+RAhVvhGVFDUdaFKe+1F8mgF0bTARrRkjVXlyOclDvRBZd6eC+
#                WtVdf6s9QIDAQAB
#   SPF   MX   send.{YOUR_DOMAIN}  feedback-smtp.us-east-1.amazonses.com  (priority 10)
#   SPF   TXT  send.{YOUR_DOMAIN}  v=spf1 include:amazonses.com ~all
#
# Set these in Supabase Edge Functions > Secrets:
# RESEND_API_KEY=re_your_resend_api_key_here
# RESEND_FROM_EMAIL=Tandril <noreply@send.{YOUR_DOMAIN}>

# ===========================================
# OTHER SETTINGS
# ===========================================
# Environment
# VITE_ENV=production
